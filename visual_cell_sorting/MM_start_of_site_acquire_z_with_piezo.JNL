<Journal><Description>For acquring z-stacks for VCS (end of site)</Description><Version VersionNumber="2.4"/><CodeBlock><CommentEntry></CommentEntry><CommentEntry>Turn autofocus off and acquire z-stacks using Piezo Z</CommentEntry><AssignVariableEntry VariableName="Camera.Digital.Exposure" Expression="180"/><FunctionEntry VersionNumber="1" GUID="{0xb0c296a0-0xea7d-0x11d5-0x9c-0x45-0x0-0x1-0x2-0x59-0x3-0xbd}" FunctionName="Select Focus Device" ApplicationName="mmproc" ExecuteMode="1" Disabled="0" Interactive="0" CommandID="1" MetaJournal="00007FFE85484FD8" IsCurrentVersion="1" Variables="00007FFE85484D38" MissingImage="0"><Variable Type="String" Name="jnlSelectFocusDevice.stNewDev" NDimensions="0" Override="" OverrideVariable="">13 Leica Z Motor</Variable><Variable Type="String" Name="jnlSelectFocusDevice.stGUID" NDimensions="0" Override="" OverrideVariable="">0 </Variable></FunctionEntry><FunctionEntry GUID="{0xffff0002-0x5716-0x4036-0xaf-0x34-0xd2-0x6c-0x83-0x10-0x4d-0xd7}" FunctionName="Stop Continuous Focusing" Interactive="0" ApplicationName="mmproc" VersionNumber="1" CommandID="2" MetaJournal="00007FFE85494820" IsCurrentVersion="1" Variables="00007FFE85494588" MissingImage="0"></FunctionEntry><FunctionEntry GUID="{0xb0c296a0-0xea7d-0x11d5-0x9c-0x45-0x0-0x1-0x2-0x59-0x3-0xbd}" FunctionName="Select Focus Device" Interactive="0" ApplicationName="mmproc" VersionNumber="1" CommandID="3" MissingImage="0" MetaJournal="00007FFE85484FD8" IsCurrentVersion="1" Variables="00007FFE85484D38"><Variable Type="String" Name="jnlSelectFocusDevice.stNewDev" NDimensions="0" Override="" OverrideVariable="">11 ASI Piezo Z</Variable><Variable Type="String" Name="jnlSelectFocusDevice.stGUID" NDimensions="0" Override="" OverrideVariable="">0 </Variable></FunctionEntry><FunctionEntry GUID="{0x79f511b3-0xe09c-0x11d3-0x93-0x9a-0x0-0x10-0x5a-0x4-0x2f-0x99}" FunctionName="Configure Stream Acquisition" Interactive="0" ApplicationName="stream" VersionNumber="20110925" CommandID="4" MissingImage="0" MetaJournal="00007FFE814111A8" IsCurrentVersion="1" Variables="00007FFE81410F08"><Variable Type="Long" Name="jnlCfgStream.nStreamFrames" NDimensions="0" Override="" OverrideVariable="">6</Variable><Variable Type="Long" Name="jnlCfgStream.nStreamFramesSkip" NDimensions="0" Override="" OverrideVariable="">0</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamResMode" NDimensions="0" Override="" OverrideVariable="">1</Variable><Variable Type="Integer" Name="jnlCfgStream.nAcqMode" NDimensions="0" Override="" OverrideVariable="">1</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamState" NDimensions="0" Override="" OverrideVariable="">1</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamShutter" NDimensions="0" Override="" OverrideVariable="">0</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamClear" NDimensions="0" Override="" OverrideVariable="">0</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamToHardDisk" NDimensions="0" Override="" OverrideVariable="">1</Variable><Variable Type="Logical" Name="jnlCfgStream.bStreamRunUserPrograms" NDimensions="0" Override="" OverrideVariable="">FALSE</Variable><Variable Type="String" Name="jnlCfgStream.stProgramNameForAcquire" NDimensions="0" Override="" OverrideVariable="">0 </Variable><Variable Type="Logical" Name="jnlCfgStream.bStreamFrameRate" NDimensions="0" Override="" OverrideVariable="">FALSE</Variable><Variable Type="Double" Name="jnlCfgStream.dpStreamFrameRate" NDimensions="0" Override="" OverrideVariable="">200</Variable><Variable Type="Logical" Name="jnlCfgStream.bStreamUsesFocusMotor" NDimensions="0" Override="" OverrideVariable="">TRUE</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamStartAt" NDimensions="0" Override="" OverrideVariable="">3</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamMoveTo" NDimensions="0" Override="" OverrideVariable="">3</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamAfter" NDimensions="0" Override="" OverrideVariable="">1</Variable><Variable Type="Logical" Name="jnlCfgStream.bStreamUsesIllum" NDimensions="0" Override="" OverrideVariable="">FALSE</Variable><Variable Type="Integer" Name="jnlCfgStream.cStreamWavelengths" NDimensions="0" Override="" OverrideVariable="">2</Variable><Variable Type="String" Name="jnlCfgStream.stIllumination" NDimensions="1" Lower1="1" Upper1="4" Override="" OverrideVariable="">11 Camera DAPI 0  0  0  </Variable><Variable Type="String" Name="jnlCfgStream.stShutterName" NDimensions="0" Override="" OverrideVariable="">10 Camera NIR</Variable><Variable Type="String" Name="jnlCfgStream.stDiskFilename" NDimensions="0" Override="" OverrideVariable="">0 </Variable><Variable Type="Logical" Name="jnlCfgStream.bOverwriteFile" NDimensions="0" Override="" OverrideVariable="">FALSE</Variable><Variable Type="Integer" Name="jnlCfgStream.nStreamFramesToAverage" NDimensions="0" Override="" OverrideVariable="">1</Variable><Variable Type="Logical" Name="jnlCfgStream.bPreviewShow" NDimensions="0" Override="" OverrideVariable="">FALSE</Variable><Variable Type="Long" Name="jnlCfgStream.cPreviewFrameInterval" NDimensions="0" Override="" OverrideVariable="">1</Variable><Variable Type="Integer" Name="jnlCfgStream.nDualState" NDimensions="0" Override="" OverrideVariable="">1</Variable><Variable Type="Logical" Name="jnlCfgStream.bSaveDuringAcquire" NDimensions="0" Override="" OverrideVariable="">FALSE</Variable><Variable Type="Logical" Name="jnlCfgStream.bSaveOneImagePerFile" NDimensions="0" Override="" OverrideVariable="">FALSE</Variable><Variable Type="Logical" Name="jnlCfgStream.bStreamUsesSpecificMoves" NDimensions="0" Override="" OverrideVariable="">FALSE</Variable><Variable Type="Integer" Name="jnlCfgStream.cSpecificItems" NDimensions="0" Override="" OverrideVariable="">0</Variable><Variable Type="Long" Name="jnlCfgStream.aiSpecStartFrame" NDimensions="1" Lower1="1" Upper1="0" Override="" OverrideVariable=""></Variable><Variable Type="Long" Name="jnlCfgSt