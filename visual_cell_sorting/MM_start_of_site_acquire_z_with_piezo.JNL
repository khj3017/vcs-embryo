</CommentEntry><FunctionEntry GUID="{0x79f510de-0xe09c-0x11d3-0x93-0x9a-0x0-0x10-0x5a-0x4-0x2f-0x99}" FunctionName="Select Image" Interactive="0" ApplicationName="journal" VersionNumber="19981104" CommandID="6" MetaJournal="00007FFE83986E80" IsCurrentVersion="1" Variables="00007FFE83986BE8" MissingImage="0"><Variable Type="Image" Name="PickImageJNL.im" NDimensions="0" Override="" OverrideVariable="">m	1 6 9 0 1 -1 -1 6 Stream </Variable><Variable Type="String" Name="PickImageJNL.prompt" NDimensions="0" Override="" OverrideVariable="">0 </Variable></FunctionEntry><AssignVariableEntry VariableName="LeicaZPos" Expression="Component.Leica_Z_Motor.Position" Disabled="1"/><AssignVariableEntry VariableName="Image.ZAbsolute" Expression="Component.Leica_Z_Motor.Position" Disabled="1"/><AssignVariableEntry VariableName="Image.FilePath" Expression="Path1_Zed" Disabled="0"/><FunctionEntry GUID="{0x3cef1e90-0xe09c-0x11d3-0x93-0x9a-0x0-0x10-0x5a-0x4-0x2f-0x99}" FunctionName="Stack Arithmetic" ApplicationName="mmproc" VersionNumber="20071131" MissingImage="0" Disabled="1" Interactive="0" CommandID="7" MetaJournal="00007FFE855DCA18" IsCurrentVersion="1" Variables="00007FFE855DC778"><Variable Type="Integer" Name="stackOpsJNL.iOperation" NDimensions="0" Override="" OverrideVariable="">3</Variable><Variable Type="Image" Name="stackOpsJNL.imStack" NDimensions="0" Override="" OverrideVariable="">m	1 6 10 0 1 -1 -1 6 Stream </Variable><Variable Type="Image" Name="stackOpsJNL.imResult" NDimensions="0" Override="" OverrideVariable="">m	0 6 9 17 1 -1 -1 10 Stream Max </Variable></FunctionEntry><FunctionEntry GUID="{0x79f510de-0xe09c-0x11d3-0x93-0x9a-0x0-0x10-0x5a-0x4-0x2f-0x99}" FunctionName="Select Image" ApplicationName="journal" VersionNumber="19981104" MissingImage="0" Disabled="1" Interactive="0" CommandID="8" MetaJournal="00007FFE83986E80" IsCurrentVersion="1" Variables="00007FFE83986BE8"><Variable Type="Image" Name="PickImageJNL.im" NDimensions="0" Override="" OverrideVariable="">m	1